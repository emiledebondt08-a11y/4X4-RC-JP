#include <PS4Controller.h>
#include <ESP32Servo.h>

// Definieer de pinnen
const int servoPin = 13; // Oranje draad van de servo
const int motorPin = 12; // Witte draad van de motordriver

Servo stuurServo;
Servo gasMotor;

void setup() {
  Serial.begin(115200);

  // Koppel de servo's aan de pinnen
  stuurServo.attach(servoPin);
  gasMotor.attach(motorPin);

  // Startpositie: Wielen recht (90), Motor stil (90)
  stuurServo.write(90);
  gasMotor.write(90);

  // VERVANG DIT door het MAC-adres dat je eerder hebt gevonden!
  PS4.begin("94:51:dc:4c:6e:a6"); 
  
  Serial.println("Klaar voor verbinding...");
}

void loop() {
  if (PS4.isConnected()) {
    
    // --- STUREN (Linker Joystick X-as) ---
    // De joystick geeft -127 tot 127. We mappen dit naar 45-135 graden voor veilig sturen.
    int stuurWaarde = PS4.LStickX();
    int servoHoek = map(stuurWaarde, -127, 127, 45, 135); 
    stuurServo.write(servoHoek);

    // --- GAS EN REM (R2 en L2) ---
    int gasInput = PS4.R2Value();    // 0 tot 255
    int remInput = PS4.L2Value();    // 0 tot 255
    int motorOutput = 90;            // Standaard stilstand

    if (gasInput > 10) {
      // Vooruit: van 90 (stil) naar 180 (vol gas)
      motorOutput = map(gasInput, 0, 255, 90, 125);
    } 
    else if (remInput > 10) {
      // Achteruit: van 90 (stil) naar 0 (vol achteruit)
      motorOutput = map(remInput, 0, 255, 90, 0);
    }

    gasMotor.write(motorOutput);

    // Debugging (optioneel, zie je in de Seriële Monitor)
    // Serial.printf("Stuur: %d | Motor: %d\n", servoHoek, motorOutput);
    
    delay(10); // Kleine pauze voor stabiliteit
  } else {
    // Als de verbinding wegvalt, zet alles stil voor de veiligheid
    stuurServo.write(90);
    gasMotor.write(90);
  }
}
